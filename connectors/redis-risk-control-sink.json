{
  "name": "redis-risk-control-sink",
  "config": {
    "connector.class": "com.redis.kafka.connect.RedisSinkConnector",
    "tasks.max": "6",
    "topics": "slot_rounds",
    "redis.uri": "redis://redis:6379",
    "redis.command": "SET",
    "redis.key": "risk:round",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",
    "transforms": "selectRiskFields",
    "transforms.selectRiskFields.type": "org.apache.kafka.connect.transforms.ReplaceField$Value",
    "transforms.selectRiskFields.include": "round_id,player_id,game_code,bet_amount,net_win,jackpot_win,is_free_spin,round_time"
  }
}
